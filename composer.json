{
    "name": "dept-of-scrapyard-robotics/hc-sr04",
    "description": "ScrapyardIO Framework extension library that enables GPIO Control of HC-SR04 Ultrasonic Distance Sensors on Linux",
    "type": "library",
    "version": "0.1.0",
    "keywords": [
        "io",
        "linux",
        "embedded",
        "gpio",
        "distance",
        "ultrasonic",
        "hc-sr04"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Project Saturn Studios, LLC",
            "email": "angel@projectsaturnstudios.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "dept-of-scrapyard-robotics/distance": "^0.1.0",
        "dept-of-scrapyard-robotics/scrapyard-io-framework": "^0.1.0"
    },
    "require-dev": {
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "*",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "ScrapyardIO\\Sensors\\Distance\\HCSR04\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests"
        }
    },
    "minimum-stability": "stable"
}
