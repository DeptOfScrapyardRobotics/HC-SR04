{
    "name": "dept-of-scrapyard-robotics/hc-sr04",
    "description": "Drive HC-SR04 ultrasonic distance sensors over GPIO with PHP",
    "type": "library",
    "version": "0.4.4",
    "keywords": ["framework", "scrapyard-io"],
    "license": "MIT",
    "homepage": "https://dosr.projectsaturnstudios.com",
    "authors": [
        {
            "name": "Angel Gonzalez",
            "email": "angel@projectsaturnstudios.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "scrapyard-io/waveforms": "^0.4.0",
        "scrapyard-io/reality-interface": "^0.4.0",
        "scrapyard-io/bare-metal": "^0.4.0"
    },
    "suggest": {
        "scrapyard-io/gpio": "^0.4.0 - For direct linux-based GPIO"
    },
    "autoload": {
        "psr-4": {
            "DeptOfScrapyardRobotics\\Sensors\\HCSR04\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DeptOfScrapyardRobotics\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
